      "bonus": "1d4"
    },
    {
      "effect_type": "skill_bonus",
      "skill": "insight",
      "bonus": "1d4"
    },
    {
      "effect_type": "spell_prepared",
      "spell": "detect magic",
      "free_cast": "1/long_rest",
      "use_slots": true
    },
    {
      "effect_type": "spell_prepared",
      "spell": "detect poison and disease",
      "free_cast": "1/long_rest",
      "use_slots": true
    },
    {
      "effect_type": "spell_prepared",
      "spell": "see invisibility",
      "free_cast": "1/long_rest",
      "use_slots": true,
      "level_required": 3
    },
    {
      "effect_type": "spellcasting_ability_choice",
      "options": [
        "int",
        "wis",
        "cha"
      ]
    },
    {
